{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/passage-v2.html", "dest": "/passage-v2.html" },
    { "src": "/", "dest": "/passage-v2.html" },
    { "src": "/(.*)", "dest": "/server/index.js" }
  ]
}
